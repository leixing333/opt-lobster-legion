{
  "$schema": "https://docs.openclaw.ai/schemas/openclaw.json",
  "_comment": "OPT 一人设计公司 OpenClaw 主配置文件 — 拷贝此文件到 ~/.openclaw/openclaw.json 即可启动龙虾军团",

  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "compaction": {
        "reserveTokensFloor": 20000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000
        }
      },
      "memorySearch": {
        "provider": "openai",
        "remote": {
          "model": "text-embedding-3-small"
        }
      }
    },
    "list": [
      {
        "id": "cos",
        "workspace": "~/.openclaw/workspace-cos",
        "agentDir": "~/.openclaw/agents/cos/agent",
        "default": true
      },
      {
        "id": "cto",
        "workspace": "~/.openclaw/workspace-cto",
        "agentDir": "~/.openclaw/agents/cto/agent"
      },
      {
        "id": "builder",
        "workspace": "~/.openclaw/workspace-builder",
        "agentDir": "~/.openclaw/agents/builder/agent"
      },
      {
        "id": "researcher",
        "workspace": "~/.openclaw/workspace-researcher",
        "agentDir": "~/.openclaw/agents/researcher/agent"
      },
      {
        "id": "ko",
        "workspace": "~/.openclaw/workspace-ko",
        "agentDir": "~/.openclaw/agents/ko/agent"
      },
      {
        "id": "ops",
        "workspace": "~/.openclaw/workspace-ops",
        "agentDir": "~/.openclaw/agents/ops/agent"
      }
    ]
  },

  "models": {
    "providers": {
      "openai": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      },
      "google": {
        "apiKey": "${GEMINI_API_KEY}"
      }
    },
    "agents": {
      "cos":        { "provider": "anthropic", "model": "claude-sonnet-4-5" },
      "cto":        { "provider": "anthropic", "model": "claude-sonnet-4-5" },
      "builder":    { "provider": "openai",    "model": "gpt-4.1-mini" },
      "researcher": { "provider": "google",    "model": "gemini-2.5-flash" },
      "ko":         { "provider": "openai",    "model": "gpt-4.1-nano" },
      "ops":        { "provider": "openai",    "model": "gpt-4.1-mini" }
    }
  },

  "channels": {
    "slack": {
      "dmPolicy": "allowlist",
      "allowFrom": ["${SLACK_OWNER_USER_ID}"],
      "accounts": {
        "default": {
          "token": "${SLACK_BOT_TOKEN}",
          "appToken": "${SLACK_APP_TOKEN}"
        }
      }
    },
    "feishu": {
      "appId": "${FEISHU_APP_ID}",
      "appSecret": "${FEISHU_APP_SECRET}"
    }
  },

  "bindings": [
    { "agentId": "cos",        "match": { "channel": "slack", "peer": { "kind": "channel", "id": "${SLACK_CHANNEL_HQ}" } } },
    { "agentId": "cto",        "match": { "channel": "slack", "peer": { "kind": "channel", "id": "${SLACK_CHANNEL_CTO}" } } },
    { "agentId": "builder",    "match": { "channel": "slack", "peer": { "kind": "channel", "id": "${SLACK_CHANNEL_BUILD}" } } },
    { "agentId": "researcher", "match": { "channel": "slack", "peer": { "kind": "channel", "id": "${SLACK_CHANNEL_RESEARCH}" } } },
    { "agentId": "ko",         "match": { "channel": "slack", "peer": { "kind": "channel", "id": "${SLACK_CHANNEL_KNOW}" } } },
    { "agentId": "ops",        "match": { "channel": "slack", "peer": { "kind": "channel", "id": "${SLACK_CHANNEL_OPS}" } } }
  ],

  "agentToAgent": {
    "allow": true,
    "maxPingPongTurns": 10
  },

  "skills": {
    "load": {
      "extraDirs": ["~/.openclaw/workspace/skills"],
      "watch": true
    }
  },

  "server": {
    "port": 18789,
    "host": "0.0.0.0"
  },

  "security": {
    "dmPolicy": "pairing",
    "sandboxing": {
      "enabled": true,
      "workspaceAccess": "rw",
      "allowAbsolutePaths": false
    }
  }
}
