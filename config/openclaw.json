{
  "version": "7.1.0",
  "name": "OPT Lobster Legion v7.1",
  "description": "Super Agent Infrastructure based on Claude Code, Hermes, and OpenHarness — with Multimodal Vision + MCP Permission Router + Google Stitch + Nano Banana",
  "engine": {
    "type": "taor",
    "maxRetries": 3,
    "timeoutMs": 300000,
    "coordinator": {
      "enabled": true,
      "mode": "swarm",
      "maxSubAgents": 3
    }
  },
  "agents": {
    "cos": {
      "role": "Chief of Staff / Product Manager",
      "model": "claude-3-7-sonnet-20250219",
      "soul": "agents/cos/SOUL.md",
      "channel": "#hq"
    },
    "cto": {
      "role": "Chief Technology Officer",
      "model": "claude-3-7-sonnet-20250219",
      "soul": "agents/cto/SOUL.md",
      "channel": "#architecture"
    },
    "fe": {
      "role": "Front-End Engineer",
      "model": "claude-3-5-sonnet-20241022",
      "soul": "agents/fe/SOUL.md",
      "channel": "#frontend"
    },
    "be": {
      "role": "Back-End Engineer",
      "model": "claude-3-5-sonnet-20241022",
      "soul": "agents/be/SOUL.md",
      "channel": "#backend"
    },
    "qa": {
      "role": "Quality Assurance Engineer",
      "model": "claude-3-5-haiku-20241022",
      "soul": "agents/qa/SOUL.md",
      "channel": "#testing"
    },
    "researcher": {
      "role": "Market & Data Researcher",
      "model": "claude-3-5-sonnet-20241022",
      "soul": "agents/researcher/SOUL.md",
      "channel": "#research"
    },
    "ko": {
      "role": "Knowledge & Evolution Officer",
      "model": "claude-3-7-sonnet-20250219",
      "soul": "agents/ko/SOUL.md",
      "channel": "#knowledge"
    },
    "ops": {
      "role": "DevOps & Security Auditor",
      "model": "claude-3-5-sonnet-20241022",
      "soul": "agents/ops/SOUL.md",
      "channel": "#ops"
    }
  },
  "memory": {
    "session": {
      "autoCompact": true,
      "compactThreshold": 0.8,
      "preserveHead": 2,
      "preserveTail": 5,
      "compactor": {
        "enabled": true,
        "engine": "engine/memory_compactor.py",
        "stateFile": "memory/session/compact_state.json",
        "maxStateSize": 2048
      }
    },
    "global": {
      "path": "memory/global/"
    },
    "profiles": {
      "dialecticalModeling": true,
      "path": "memory/profiles/"
    },
    "trajectories": {
      "enabled": true,
      "format": "jsonl",
      "path": "memory/trajectories/"
    },
    "driftCaveat": {
      "enabled": true,
      "warnAfterHours": 24,
      "cautionAfterDays": 7,
      "archiveAfterDays": 30,
      "scanDirs": ["memory/global", "memory/profiles", "memory/session"]
    }
  },
  "kairos": {
    "enabled": true,
    "daemon": "engine/kairos_daemon.py",
    "logDir": "memory/kairos_logs",
    "logLevels": ["DECISION", "STATUS", "ESCALATION", "MILESTONE", "NOTE"],
    "dailySummary": {
      "enabled": true,
      "triggerTime": "23:55",
      "outputPath": "memory/kairos_logs/summaries/"
    }
  },
  "skills": {
    "corePath": "skills/core/",
    "evolvedPath": "skills/evolved/",
    "autoEvolution": true
  },
  "hooks": {
    "preToolUse": "hooks/pre_tool_use/",
    "postToolUse": "hooks/post_tool_use/"
  },
  "permissions": {
    "mode": "plan",
    "defaultAction": "ask",
    "blockedCommands": ["rm -rf /", "mkfs", "dd"],
    "allowedPaths": ["/home/ubuntu/workspace"]
  },
  "mcp": {
    "servers": {
      "github": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"]
      },
      "postgres": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://localhost/mydb"]
      }
    }
  },
  "vision": {
    "enabled": true,
    "engine": "engine/vision_parser.py",
    "defaultBackend": "openai",
    "model": "gpt-4o",
    "similarityThreshold": 0.9,
    "outputDir": "workspace/components/"
  },
  "mcpRouter": {
    "enabled": true,
    "engine": "engine/mcp_router.py",
    "auditLog": "memory/kairos_logs/mcp_audit.jsonl",
    "failClosed": true,
    "permissionMatrix": "config/mcp_permissions.json"
  },
  "stitch": {
    "enabled": true,
    "client": "engine/stitch_client.py",
    "sdkPackage": "@google/stitch-sdk",
    "mcpServer": "stitch.googleapis.com",
    "auth": {
      "apiKeyEnv": "STITCH_API_KEY",
      "accessTokenEnv": "STITCH_ACCESS_TOKEN",
      "projectIdEnv": "STITCH_PROJECT_ID"
    },
    "defaultDeviceType": "web",
    "pipeline": {
      "autoEnhanceWithNanaBanana": true,
      "outputDir": "workspace/stitch_output/",
      "saveHtml": true,
      "saveScreenshot": true
    },
    "agents": {
      "fe": ["generate_ui", "edit_screen", "generate_variants", "full_pipeline"],
      "cos": ["generate_variants", "list_projects"],
      "cto": ["list_projects", "list_screens"]
    }
  },
  "nanaBanana": {
    "enabled": true,
    "client": "engine/nano_banana_client.py",
    "auth": {
      "apiKeyEnv": "GOOGLE_API_KEY",
      "fallbackEnv": "GEMINI_API_KEY"
    },
    "models": {
      "default": "gemini-3.1-flash-image-preview",
      "pro": "gemini-3-pro-image-preview",
      "fast": "gemini-2.5-flash-image"
    },
    "defaultAspectRatio": "16:9",
    "agents": {
      "fe": ["generate_ui_assets", "text_to_image", "image_to_image", "generate_design_variants"],
      "cos": ["text_to_image"],
      "researcher": ["text_to_image"]
    },
    "stitchIntegration": {
      "enabled": true,
      "autoEnhanceScreenshots": true,
      "enhancementModel": "gemini-3-pro-image-preview"
    }
  },
  "scheduler": {
    "autoDream": {
      "cron": "0 2 * * 1",
      "script": "engine/auto_dream.py",
      "description": "每周一凌晨 2:00 执行 Auto Dream（含 Memory Drift Caveat 扫描）"
    },
    "kairosDaily": {
      "cron": "55 23 * * *",
      "script": "engine/kairos_daemon.py summary",
      "description": "每天 23:55 生成当日 KAIROS 日志摘要"
    }
  }
}
