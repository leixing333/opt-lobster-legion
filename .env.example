# ╔══════════════════════════════════════════════════════════════╗
# ║   OPT 龙虾军团 v3.0 — 环境变量配置模板                       ║
# ║   复制此文件为 .env 并填入真实值                              ║
# ╚══════════════════════════════════════════════════════════════╝

# ===== AI 模型 API Keys =====
# CoS 和 CTO 使用（推荐 Claude 3.5 Sonnet）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Builder 和 Ops 使用（推荐 GPT-4.1-mini）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Researcher 使用（推荐 Gemini 2.5 Flash）
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Slack 配置 =====
# Slack Bot Token（xoxb-...）
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxx

# Slack App Token（xapp-...）
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxxxxxx

# 老板的 Slack User ID（用于 DM 白名单）
SLACK_OWNER_USER_ID=U0XXXXXXX

# Slack 频道 ID（在频道设置中查看）
SLACK_CHANNEL_HQ=C0XXXXXXX
SLACK_CHANNEL_CTO=C0XXXXXXX
SLACK_CHANNEL_BUILD=C0XXXXXXX
SLACK_CHANNEL_RESEARCH=C0XXXXXXX
SLACK_CHANNEL_KNOW=C0XXXXXXX
SLACK_CHANNEL_OPS=C0XXXXXXX

# ===== 飞书配置（可选，与 Slack 二选一）=====
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ===== 备份配置 =====
# GitHub 私有仓库地址（用于备份）
BACKUP_GITHUB_REPO=https://github.com/your-name/opt-backup.git
BACKUP_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# ===== 知识库配置 =====
# 向量数据库（可选，默认使用本地文件）
VECTOR_DB_URL=
VECTOR_DB_API_KEY=
