# OPT 龙虾军团 — 环境变量配置模板
# 复制此文件为 .env，填入真实值后使用
# 警告：.env 文件绝对不能提交到 Git！

# ===== AI 模型 API Keys =====
ANTHROPIC_API_KEY=sk-ant-xxxxx          # Claude 系列模型
OPENAI_API_KEY=sk-xxxxx                 # GPT 系列模型
GEMINI_API_KEY=AIzaSyxxxxx              # Gemini 系列模型

# ===== 通信平台 =====
# Slack
SLACK_BOT_TOKEN=xoxb-xxxxx
SLACK_APP_TOKEN=xapp-xxxxx
SLACK_OWNER_USER_ID=U0XXXXXXX           # 你的 Slack 用户 ID

# Slack 频道 ID（在频道设置中查看）
SLACK_CHANNEL_HQ=C0XXXXXXX             # #hq
SLACK_CHANNEL_CTO=C0XXXXXXX            # #cto
SLACK_CHANNEL_BUILD=C0XXXXXXX          # #build
SLACK_CHANNEL_RESEARCH=C0XXXXXXX       # #research
SLACK_CHANNEL_KNOW=C0XXXXXXX           # #know
SLACK_CHANNEL_OPS=C0XXXXXXX            # #ops

# 飞书（可选，与 Slack 二选一）
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx

# ===== 工具 API Keys =====
SERPER_API_KEY=xxxxx                    # Google 搜索 API
GITHUB_TOKEN=ghp_xxxxx                  # GitHub API（用于备份）
VERCEL_TOKEN=xxxxx                      # Vercel 部署

# ===== 存储配置 =====
BACKUP_GITHUB_REPO=https://github.com/{你的用户名}/opt-backup.git

# ===== 系统配置 =====
OPENCLAW_PORT=18789
TOKEN_BUDGET_DAILY=500000               # 每日 Token 预算（超出时 Ops 报警）
